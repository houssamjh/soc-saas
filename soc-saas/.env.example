# PostgreSQL
POSTGRES_USER=soc_admin
POSTGRES_PASSWORD=socpassword123
POSTGRES_DB=socdb

# Elasticsearch
ELASTIC_HOST=elasticsearch
ELASTIC_PORT=9200

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Redis
REDIS_URL=redis://redis:6379

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin123
KEYCLOAK_REALM=soc
KEYCLOAK_CLIENT_ID=soc-frontend

# JWT
JWT_SECRET_KEY=change-me-in-production-super-secret-key
JWT_ALGORITHM=HS256

# Services
SIEM_SERVICE_URL=http://siem-service:8001
CASE_SERVICE_URL=http://case-service:8002
TI_SERVICE_URL=http://ti-service:8003
SOAR_SERVICE_URL=http://soar-service:8004

# Frontend
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_WS_URL=ws://localhost/ws

# ClickHouse
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=soc_analytics

# Grafana
GF_SECURITY_ADMIN_PASSWORD=admin
GF_AUTH_ANONYMOUS_ENABLED=true
GF_AUTH_ANONYMOUS_ORG_ROLE=Viewer
